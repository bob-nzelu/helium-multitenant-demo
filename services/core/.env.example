# Helium Core Database Configuration
# Copy this file to .env and fill in the values
# DO NOT commit .env to version control

# PostgreSQL credentials
HELIUM_DB_HOST=localhost
HELIUM_DB_PORT=5432
HELIUM_DB_USER=helium_admin
HELIUM_DB_PASSWORD=your_strong_password_min_32_characters_here

# Database names
HELIUM_INVOICES_DB=invoices
HELIUM_CUSTOMERS_DB=customers
HELIUM_INVENTORY_DB=inventory
HELIUM_NOTIFICATIONS_DB=notifications
HELIUM_CORE_DB=core

# SQLite paths (test environment)
HELIUM_INVOICES_TEST_DB=./data/test/invoices_test.db
HELIUM_CORE_TEST_DB=./data/test/core.db

# Connection pool settings
HELIUM_DB_POOL_SIZE=10
HELIUM_DB_POOL_TIMEOUT=30
